{
  "manifest_version": 2,
  "name": "RootCause",
  "version": "1.0.0",
  "description": "DevTools extension that explains WHY your website is slow in plain English, not just WHAT is wrong. Get root-cause narratives with actionable fixes.",
  "permissions": [
    "debugger",
    "tabs",
    "scripting",
    "storage",
    "<all_urls>"
  ],
  "devtools_page": "devtools/devtools.html",
  "background": {
    "scripts": ["background/service-worker.js"],
    "persistent": false
  },
  "icons": {
    "16": "icons/analytics.png",
    "48": "icons/analytics.png",
    "128": "icons/analytics.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/analytics.png",
      "48": "icons/analytics.png",
      "128": "icons/analytics.png"
    }
  },
  "applications": {
    "gecko": {
      "id": "rootcause@performance.detective",
      "strict_min_version": "57.0"
    }
  }
}
