{
  "manifest_version": 3,
  "name": "RootCause",
  "version": "1.0.0",
  "description": "Chrome DevTools extension that explains WHY your website is slow in plain English, not just WHAT is wrong. Get root-cause narratives with actionable fixes.",
  "permissions": [
    "debugger",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "devtools_page": "devtools/devtools.html",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/analytics.png",
    "48": "icons/analytics.png",
    "128": "icons/analytics.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/analytics.png",
      "48": "icons/analytics.png",
      "128": "icons/analytics.png"
    }
  }
}
